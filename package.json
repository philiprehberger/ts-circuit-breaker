{
  "name": "@philiprehberger/circuit-breaker",
  "version": "0.1.2",
  "description": "Circuit breaker pattern for fault-tolerant async service calls",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "circuit-breaker",
    "fault-tolerance",
    "resilience",
    "retry",
    "microservice"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-circuit-breaker.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-circuit-breaker#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-circuit-breaker/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
